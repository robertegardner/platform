{
  "_comment": "Device registry — source of truth for device -> antenna -> filter -> band -> domain -> endpoint. Replaces the RF switch. The pi-acquisition provisioner iterates `present: true` devices only; flip present + re-apply to join a new tuner. See docs/acquisition_tier.md and docs/PLATFORM_V2_ARCHITECTURE.md.",
  "devices": {
    "dx-r2": {
      "present": true,
      "soapy_args": "driver=sdrplay",
      "antenna": "Antenna A",
      "feed": "Shakespeare 5120",
      "filter": "FM bandpass",
      "role": "fm-multistation",
      "domain": "radio",
      "transport": "soapy-remote",
      "wire_format": "CS16",
      "endpoint": "tcp://radio.srvr:55001",
      "port": 55001,
      "sample_rate_max": 8000000,
      "bias_tee": false,
      "usb_controller": "A"
    },
    "hf-plus": {
      "present": false,
      "soapy_args": "driver=airspyhf",
      "antenna": "single",
      "feed": "YouLoop (primary) / long-wire (alt)",
      "filter": "HF choke on long-wire",
      "role": "am-broadcast",
      "domain": "radio",
      "transport": "soapy-remote",
      "wire_format": "CS16",
      "endpoint": "tcp://radio.srvr:55002",
      "port": 55002,
      "bias_tee": false,
      "usb_controller": "A"
    },
    "rtl-2838": {
      "_comment": "INTERIM scanner source — the existing Nooelec RTL2838 that ran SDRTrunk on the Pi until the 2026-06 P25 offload. Serves the scanner domain over SoapyRemote (same transport the R2 will use) until the Airspy R2 arrives; then flip this to present:false and airspy-r2 to true in the same change. Single client = rack op25; the Pi-side monitor/manual-tune rtl_fm jobs lose the dongle while this is present.",
      "present": true,
      "soapy_args": "driver=rtlsdr",
      "antenna": "single",
      "feed": "discone",
      "filter": "none",
      "role": "scanner-p25-interim",
      "domain": "scanner",
      "transport": "soapy-remote",
      "wire_format": "CU8",
      "endpoint": "tcp://radio.srvr:55005",
      "port": 55005,
      "sample_rate_default": 2400000,
      "bias_tee": false,
      "usb_controller": "A"
    },
    "airspy-r2": {
      "present": false,
      "soapy_args": "driver=airspy",
      "antenna": "single",
      "feed": "discone",
      "filter": "Flamingo FM band-stop",
      "role": "scanner-terrestrial",
      "domain": "scanner",
      "transport": "soapy-remote",
      "wire_format": "CS16",
      "endpoint": "tcp://radio.srvr:55003",
      "port": 55003,
      "sample_rate_default": 2500000,
      "bias_tee": false,
      "usb_controller": "B"
    },
    "rtl-v4": {
      "present": false,
      "soapy_args": "driver=rtlsdr",
      "antenna": "single",
      "feed": "V-dipole",
      "filter": "Sawbird+ NOAA (LNA)",
      "role": "meteor-lrpt",
      "domain": "radio",
      "transport": "soapy-remote",
      "wire_format": "CU8",
      "endpoint": "tcp://radio.srvr:55004",
      "port": 55004,
      "bias_tee": true,
      "usb_controller": "B"
    }
  }
}
