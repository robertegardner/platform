# =============================================================================
# .gitignore — NEVER commit these files
# =============================================================================

# Terraform secrets and state (terraform.tfvars lives on thebeast only)
terraform/terraform.tfvars
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/terraform.tfstate
terraform/terraform.tfstate.backup
terraform/*.tfplan

# Backup files
*.bak
*.orig

# SSH keys (never commit)
*.pem
*.key
id_rsa
id_ed25519

# OS
.DS_Store
Thumbs.db

# Claude Code local state
.claude/

# Python bytecode cache
__pycache__/
*.pyc
